<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bunnix">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".BunnixApplication"
        android:allowBackup="true"
        android:icon="@drawable/img"
        android:label="@string/app_name"
        android:roundIcon="@drawable/img"
        android:supportsRtl="true"
        android:theme="@style/Theme.Bunnix.Splash">

        <activity
            android:name=".MainActivity"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity
            android:name=".frontend.SplashActivity"
            android:exported="false">
        </activity>

        <activity
            android:name="com.example.bunnix.frontend.LoginActivity"
            android:exported="false" />

        <activity
            android:name="com.example.bunnix.frontend.SignupActivity"
            android:exported="false" />

<!--        <activity-->
<!--            android:name="com.example.bunnix.MainActivity"-->
<!--            android:exported="false" />-->

<!--        <activity-->
<!--            android:name="com.example.bunnix.vendorUI.screens.vendor.dashboard.VendorMainActivity"-->
<!--            android:exported="false" />-->

        <activity
            android:name="com.example.bunnix.frontend.OnboardingActivity"
            android:exported="false" />

        <!-- ✅ ADD THIS - VENDOR MODE ENTRY -->
        <activity
            android:name="com.example.bunnix.vendorUI.VendorMainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>